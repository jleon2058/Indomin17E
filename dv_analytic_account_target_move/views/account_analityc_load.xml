<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record forcecreate="True" id="loan_expiration_email" model="ir.cron">
      <field name="name">Envio de Correo sobre Centro de Costo</field>
      <field name="active" eval="True" />
      <field name="user_id" ref="base.user_root" />
      <field name="interval_number">7</field>
      <field name="interval_type">days</field>
      <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 13:00:00')" />
      <field name="numbercall">-1</field>
      <field name="model_id" ref="model_account_analytic_account"/>
      <field name="state">code</field>
      <field name="code">model.email_loan()</field>
      <field name="doall" eval="False"/>
  </record>
</odoo>